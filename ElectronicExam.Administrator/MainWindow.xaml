<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ElectronicExam.Administrator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ElectronicExam.Administrator"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="GlobalNavigator"
                    SelectionChanged="GlobalNavigator_SelectionChanged"
                    IsSettingsVisible="False"
                    IsBackEnabled="True"
                    BackRequested="GlobalNavigator_BackRequested"
                    PaneTitle="Admin">
        <NavigationView.MenuItems>
            <NavigationViewItem Icon="Home"
                                Content="Home"
                                Tag="HomeView"
                                IsSelected="True"/>
            <NavigationViewItem Icon="People"
                                Content="Students"
                                Tag="StudentsView" />
            <NavigationViewItem Icon="ShowResults"
                                Content="Exams"
                                Tag="ExamsView" />
            <NavigationViewItemSeparator />
            <NavigationViewItem Icon="Edit"
                                Content="Set Exam Questions"
                                Tag="NewExamQuestion" />
        </NavigationView.MenuItems>
        <Frame x:Name="ContentFrame" Padding="10" />
    </NavigationView>
</Window>
