<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ElectronicExam.Administrator.Updaters.UpdateExam"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ElectronicExam.Administrator.Updaters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:conv="using:ElectronicExam.Administrator.valueConverters"
      mc:Ignorable="d">
    <Page.Resources>
        <conv:StringToDecimal x:Key="toDecimal" />
    </Page.Resources>

    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox Header="Teacher Name"
                 PlaceholderText="Teacher Name"
                 Text="{Binding TeacherName ,Mode=TwoWay}" />
        <TextBox Header="Subject Name"
                 PlaceholderText="Subject Name"
                 Text="{Binding SubjectName,Mode=TwoWay}"
                 Grid.Row="1" />
        <TextBox Header="Title "
                 PlaceholderText="Title "
                 Text="{Binding Title,Mode=TwoWay}"
                 Grid.Row="2" />
        <DatePicker Grid.Row="3"
               Header="Date"
               x:Name="DateSelector"
               MonthFormat="{}{month.integer(2)}"/>
        <TimePicker Grid.Row="4"
               Header="Time"
               HorizontalAlignment="Stretch"
               x:Name="TimeSelector"/>
        <TextBox Header="Exam Duration"
            Grid.Row="5"
            Text="{Binding ExamDuration,Mode=TwoWay,Converter={StaticResource toDecimal}}"
            HorizontalAlignment="Stretch"
            PlaceholderText="Minute" />

        <Button Content="Save"
                x:Name="SaveButton"
                Click="SaveButton_Click"
                HorizontalAlignment="Stretch"
                Grid.Row="6" />
    </Grid>
</Page>
