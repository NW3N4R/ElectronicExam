<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Updaters.UpdateQuestion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Updaters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:conv="using:ElectronicExam.Administrator.valueConverters"
      mc:Ignorable="d">
    <Page.Resources>
        <conv:StringToByteConverter x:Key="toByte" />
    </Page.Resources>
    <Grid RowSpacing="10" MinWidth="520">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <TextBox Header="Question"
                 PlaceholderText="The Question?"
                 Text="{Binding Question,Mode=TwoWay}" />
        <TextBox Header="Explaining"
                 PlaceholderText="Explain The Question Here"
                 Text="{Binding Explaining,Mode=TwoWay}"
                 Grid.Row="1" />
        <Grid Grid.Row="2"
              ColumnSpacing="10"
              RowSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBox Header="Answeer A"
                     PlaceholderText="Answeer A"
                     Text="{Binding AnsA,Mode=TwoWay}" />
            <TextBox Header="Answeer B"
                     PlaceholderText="Answeer B"
                     Text="{Binding AnsB,Mode=TwoWay}"
                     Grid.Column="1" />
            <TextBox Header="Answeer C"
                     PlaceholderText="Answeer C"
                     Text="{Binding AnsC,Mode=TwoWay}"
                     Grid.Row="1" />
            <TextBox Header="Answeer D"
                     PlaceholderText="Answeer D"
                     Text="{Binding AnsD,Mode=TwoWay}"
                     Grid.Column="1"
                     Grid.Row="1" />
            <ComboBox Header="Correct Answeer"
                      HorizontalAlignment="Stretch"
                      SelectedItem="{Binding CorrectAnsweer}"
                      Grid.Row="2">
                <x:String>A</x:String>
                <x:String>B</x:String>
                <x:String>C</x:String>
                <x:String>D</x:String>
            </ComboBox>
            <TextBox Header="Mark"
                     PlaceholderText="Mark"
                     Grid.Column="1"
                     Grid.Row="2"
                     Text="{Binding Mark,Mode=TwoWay,Converter={StaticResource toByte}}" />
        </Grid>
    </Grid>
</Page>
