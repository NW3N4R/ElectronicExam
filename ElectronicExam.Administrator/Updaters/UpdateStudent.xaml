<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Updaters.UpdateStudent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Updaters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:conv="using:ElectronicExam.Administrator.valueConverters"
      mc:Ignorable="d">
    <Page.Resources>
        <conv:StringToByteConverter x:Key="toByte" />
    </Page.Resources>
    <Grid RowSpacing="10"
          ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"
                              MinWidth="200" />
            <ColumnDefinition Width="*"
                              MinWidth="200" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox Header="First Name"
                 PlaceholderText="First Name"
                 Text="{Binding FirstName,Mode=TwoWay}" />
        <TextBox Header="Second Name"
                 PlaceholderText="Second Name"
                 Text="{Binding MiddleName,Mode=TwoWay}"
                 Grid.Column="1" />
        <TextBox Header="Last Name"
                 PlaceholderText="Last Name"
                 Text="{Binding LastName,Mode=TwoWay}"
                 Grid.Row="1" />
        <TextBox Header="Phone"
                 PlaceholderText="07xx xxx xxxx"
                 Text="{Binding Phone,Mode=TwoWay}"
                 Grid.Column="2"
                 Grid.Row="1" />
        <TextBox Header="Email"
                 PlaceholderText="someone@example.com"
                 Text="{Binding Email,Mode=TwoWay}"
                 Grid.Row="2" />
        <ComboBox Header="Gender"
                  SelectedItem="{Binding Gender,Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  Grid.Column="1"
                  Grid.Row="2">
            <x:String>Male</x:String>
            <x:String>Female</x:String>
        </ComboBox>
        <ComboBox Header="Stage"
                  PlaceholderText="Stage"
                  x:Name="StageCm"
                  SelectionChanged="StageCm_SelectionChanged"
                  SelectedItem="{Binding Stage,Mode=TwoWay,Converter={StaticResource toByte}}"
                  Grid.Row="3"
                  HorizontalAlignment="Stretch">
            <x:String>1</x:String>
            <x:String>2</x:String>
            <x:String>3</x:String>
            <x:String>4</x:String>
            <x:String>5</x:String>
        </ComboBox>
        <ComboBox Header="Group"
                  PlaceholderText="Group"
                  x:Name="GroupCm"
                  SelectedItem="{Binding Group,Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  Grid.Column="1"
                  Grid.Row="3">
        </ComboBox>
        <Button Content="Update"
                x:Name="UpdateButton"
                Click="UpdateButton_Click"
                Grid.Row="5"
                Grid.Column="1"
                HorizontalAlignment="Stretch" />
    </Grid>
</Page>
