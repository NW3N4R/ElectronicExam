<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Updaters.UpdateStudent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Updaters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid RowSpacing="10"
          Padding="5"
          MinWidth="200">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox Header="Student Full Name"
                 PlaceholderText="Student Full Name"
                 Text="{Binding StudentName,Mode=TwoWay}" />
        <TextBox Header="Class Name"
                 PlaceholderText="Class Name"
                 Text="{Binding ClassName,Mode=TwoWay}"
                 Grid.Row="1" />
        <TextBox Header="Grade"
                 PlaceholderText="Grade"
                 Text="{Binding Grade,Mode=TwoWay}"
                 Grid.Row="2" />
        <Button Content="Update"
                x:Name="UpdateButton"
                Click="UpdateButton_Click"
                Grid.Row="3"
                HorizontalAlignment="Stretch" />
    </Grid>
</Page>
