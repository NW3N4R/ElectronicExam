<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Views.HomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      Loaded="Page_Loaded"
      mc:Ignorable="d">

    <Grid ColumnSpacing="15"
          RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Frame CornerRadius="10"
               Padding="10"
               Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center">
            <StackPanel>
                <TextBlock Text="{Binding StudentsNo}"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           TextAlignment="Center" />
                <TextBlock Text="Total Students"
                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Frame>
        <Frame CornerRadius="10"
               Padding="10"
               Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center"
               Grid.Column="1">
            <StackPanel>
                <TextBlock Text="{Binding TeachersNo}"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           TextAlignment="Center" />
                <TextBlock Text="Total Teachers"
                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Frame>
        <Frame CornerRadius="10"
               Padding="10"
               Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center"
               Grid.Column="2">
            <StackPanel>
                <TextBlock Text="{Binding ExamsNo}"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           TextAlignment="Center" />
                <TextBlock Text="Exam No"
                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Frame>
        <Frame CornerRadius="10"
               Padding="10"
               Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center"
               Grid.Column="3">
            <StackPanel>
                <TextBlock Text="{Binding PassedStudents}"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           TextAlignment="Center" />
                <TextBlock Text="Success Students"
                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Frame>
        <Frame CornerRadius="10"
               Padding="10"
               Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center"
               Grid.Row="1">
            <StackPanel>
                <TextBlock Text="{Binding FailedStudents}"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           TextAlignment="Center" />
                <TextBlock Text="Failed Students"
                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Frame>
        <Frame CornerRadius="10"
               Padding="10"
               Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center"
               Grid.Row="1"
               Grid.Column="1">
            <StackPanel>
                <TextBlock Text="{Binding RateOfSuccess}"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           TextAlignment="Center" />
                <TextBlock Text="Rate of Success Students"
                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Frame>
        <Frame CornerRadius="10"
               Padding="10"
               Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center"
               Grid.Row="1"
               Grid.Column="2">
            <StackPanel>
                <TextBlock Text="{Binding RateOfFail}"
                           Style="{ThemeResource TitleLargeTextBlockStyle}"
                           TextAlignment="Center" />
                <TextBlock Text="Rate of Failed Students"
                           Style="{ThemeResource BodyLargeTextBlockStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Frame>
    </Grid>
</Page>
