<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Views.ExamQuestionsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      Loaded="Page_Loaded"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"
              ColumnSpacing="40"
              Padding="10"
              CornerRadius="10"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Padding="10"
                  CornerRadius="10"
                  ColumnSpacing="20"
                  RowSpacing="10"
                  Background="{ThemeResource CardStrokeColorDefault}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Instructor"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding header.TeacherName}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="2">
                    <TextBlock Text="Subject"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding header.SubjectName}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Exam Title"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding header.Title}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
            </Grid>
            <Grid Padding="10"
                  CornerRadius="10"
                  ColumnSpacing="20"
                  Grid.Column="1"
                  RowSpacing="10"
                  Background="{ThemeResource CardStrokeColorDefault}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Exam Date"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding header.getDate}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Exam Time"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding header.ETime}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Exam Total Mark"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding TotalMark}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Grid.Column="1">
                    <TextBlock Text="Total Questions"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding TotalQuestions}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
            </Grid>
            <Grid Padding="10"
                  CornerRadius="10"
                  ColumnSpacing="20"
                  Grid.Column="2"
                  RowSpacing="10"
                  Background="{ThemeResource CardStrokeColorDefault}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        x:Name="RefreshBttn"
                        Click="RefreshBttn_Click">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="Refresh"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        x:Name="AddQuestion"
                        Click="AddQuestion_Click"
                        Background="Transparent"
                        BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                        <SymbolIcon Symbol="Add" />
                        <TextBlock Text="Add Question"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        x:Name="RemoveExam"
                        Click="RemoveExam_Click">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                        <SymbolIcon Symbol="Delete" />
                        <TextBlock Text="Remove This Exam"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
        <ListView Grid.Row="1"
                  ItemsSource="{Binding tempQuestions}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="10"
                                CornerRadius="10"
                                Margin="0,5,0,5"
                                Background="{ThemeResource CardStrokeColorDefault}"
                                Spacing="10">
                        <StackPanel>
                            <TextBlock Text="{Binding Question,Mode=TwoWay}"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="{Binding Explaining,Mode=TwoWay}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Grid.Row="1" />
                        </StackPanel>
                        <Grid Margin="0,5,0,0"
                              ColumnSpacing="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto" />
                                <RowDefinition Height="auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding AnsA}" />
                            <TextBlock Text="{Binding AnsB}"
                                       Grid.Column="1" />
                            <TextBlock Text="{Binding AnsC}"
                                       Grid.Row="1" />
                            <TextBlock Text="{Binding AnsC}"
                                       Grid.Row="1"
                                       Grid.Column="1" />
                        </Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="10">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4">
                                <TextBlock Text="Correct Answeer:"
                                           Grid.Row="1"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CorrectAnsweer}"
                                           Grid.Row="1"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4">
                                <TextBlock Text="Mark:"
                                           Grid.Row="1"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Mark}"
                                           Grid.Row="1"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="0">
                                <AppBarButton LabelPosition="Collapsed"
                                              Icon="Edit"
                                              Tag="{Binding id}"
                                              x:Name="UpdateQuestionBttn"
                                              Click="UpdateQuestionBttn_Click" />
                                <AppBarButton LabelPosition="Collapsed"
                                              Icon="Delete"
                                              Tag="{Binding id}"
                                              x:Name="DeleteQuestionBttn"
                                              Click="DeleteQuestionBttn_Click" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
