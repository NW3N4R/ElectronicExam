<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Views.ExamsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:NewExam="using:ElectronicExam.Administrator.Uploaders"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="5"
              Padding="10,5,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="CleanFilters"
                    Click="CleanFilters_Click">
                <SymbolIcon Symbol="Refresh" />
            </Button>
            <Button Content="New Exam"
                    Grid.Column="1">
                <Button.Flyout>
                    <Flyout>
                        <NewExam:NewExam />
                    </Flyout>
                </Button.Flyout>
            </Button>
            <ComboBox x:Name="TeachersFilterCombo"
                      Grid.Column="2"
                      SelectedIndex="0"
                      MinWidth="120"
                      VerticalAlignment="Center"
                      SelectionChanged="TeachersFilterCombo_SelectionChanged" />
            <ComboBox x:Name="SubjectsFilterCombo"
                      Grid.Column="3"
                      SelectedIndex="0"
                      MinWidth="120"
                      VerticalAlignment="Center"
                      SelectionChanged="SubjectsFilterCombo_SelectionChanged" />
            <DatePicker x:Name="FilterByDate"
                        HorizontalAlignment="Stretch"
                        MonthFormat="{}{month.integer(2)}"
                        SelectedDateChanged="FilterByDate_SelectedDateChanged"
                        Grid.Column="4" />

        </Grid>
        <ListView x:Name="mylist"
                  x:FieldModifier="Public"
                  Grid.Row="1">
            <ListView.Header>
                <Grid ColumnSpacing="10"
                      Padding="10,5,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto"
                                          MinWidth="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Teacher Name" />
                    <TextBlock Text="Subject Name"
                               Grid.Column="1" />
                    <TextBlock Text="Title"
                               Grid.Column="2" />
                    <TextBlock Text="Date"
                               Grid.Column="3" />
                    <TextBlock Text="Time"
                               Grid.Column="4" />
                    <TextBlock Text="Duration"
                               Grid.Column="5" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto"
                                              MinWidth="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding TeacherName}" />
                        <TextBlock Text="{Binding SubjectName}"
                                   Grid.Column="1" />
                        <TextBlock Text="{Binding Title}"
                                   Grid.Column="2" />
                        <TextBlock Text="{Binding getDate}"
                                   Grid.Column="3" />
                        <TextBlock Text="{Binding ETime}"
                                   Grid.Column="4" />
                        <TextBlock Text="{Binding Duration}"
                                   Grid.Column="5" />
                        <Button Grid.Column="6"
                                Background="Transparent"
                                BorderBrush="Transparent">
                            <SymbolIcon Symbol="More" />
                            <Button.Flyout>
                                <Flyout Placement="LeftEdgeAlignedTop">
                                    <StackPanel Spacing="10">
                                        <Button Tag="{Binding id}"
                                                x:Name="UpdateTeacher"
                                                Click="UpdateTeacher_Click"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                HorizontalContentAlignment="Left"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <SymbolIcon Symbol="Edit" />
                                                <TextBlock Text="Edit" />
                                            </StackPanel>
                                        </Button>
                                        <Button Tag="{Binding id}"
                                                x:Name="DeleteTeacher"
                                                Click="DeleteTeacher_Click"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <SymbolIcon Symbol="Delete" />
                                                <TextBlock Text="Delete" />
                                            </StackPanel>
                                        </Button>
                                        <Button Tag="{Binding id}"
                                                x:Name="ViewQuestions"
                                                Click="ViewQuestions_Click"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <SymbolIcon Symbol="List" />
                                                <TextBlock Text="View Questions" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
