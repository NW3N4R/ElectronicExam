<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Views.StudentsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:newStudent="using:ElectronicExam.Administrator.Uploaders"
      xmlns:helper="using:ElectronicExam.Administrator.Helpers"
      mc:Ignorable="d">
    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="10"
              Padding="10,5,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0.1*" />
            </Grid.ColumnDefinitions>
            <Button Content="New Student">
                <Button.Flyout>
                    <Flyout>
                        <newStudent:NewStudent />
                    </Flyout>
                </Button.Flyout>
            </Button>
            <TextBox PlaceholderText="Search"
                     x:Name="SearchTXT"
                     TextChanging="SearchTXT_TextChanged"
                     Grid.Column="1">
            </TextBox>
        </Grid>
        <ListView x:Name="myListView"
                  x:FieldModifier="Public"
                  Grid.Row="1">
            <ListView.Header>
                <Grid Padding="15,0,15,0"
                      ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Student Name" />

                    <TextBlock Grid.Column="1"
                               Text="Code" />
                    <TextBlock Grid.Column="2"
                               Text="ClassName" />
                    <TextBlock Grid.Column="3"
                               Text="Grade" />
                    <TextBlock Grid.Column="4"
                               Text="Actions" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="20"
                          Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding StudentName}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Code}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ClassName}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Grade}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="4"
                                Background="Transparent"
                                BorderBrush="Transparent">
                            <SymbolIcon Symbol="More" />
                            <Button.Flyout>
                                <Flyout Placement="Left">
                                    <StackPanel Spacing="10">
                                        <Button Tag="{Binding id}"
                                                x:Name="UpdateStudent"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Click="UpdateStudent_Click"
                                                HorizontalContentAlignment="Left"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <SymbolIcon Symbol="Edit" />
                                                <TextBlock Text="Edit" />
                                            </StackPanel>
                                        </Button>
                                        <Button Tag="{Binding id}"
                                                x:Name="DeleteStudent"
                                                Click="DeleteStudent_Click"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <SymbolIcon Symbol="Delete" />
                                                <TextBlock Text="Delete" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
