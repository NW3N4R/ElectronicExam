<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ElectronicExam.Administrator.Views.StudentsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ElectronicExam.Administrator.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:newStudent="using:ElectronicExam.Administrator.Uploaders"
      xmlns:helper="using:ElectronicExam.Administrator.Helpers"
      mc:Ignorable="d">
    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="10"
              Padding="10,5,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0.1*" />
            </Grid.ColumnDefinitions>
            <Button Content="New Student">
                <Button.Flyout>
                    <Flyout>
                        <newStudent:NewStudent />
                    </Flyout>
                </Button.Flyout>
            </Button>
            <TextBox PlaceholderText="Search"
                     x:Name="SearchTXT"
                     TextChanging="SearchTXT_TextChanged"
                     Grid.Column="1">
            </TextBox>
        </Grid>
        <ListView x:Name="myListView"
                  x:FieldModifier="Public"
                  Grid.Row="1">

            <ListView.Header>
                <Grid Padding="15,0,15,0"
                      ColumnSpacing="40">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalTextAlignment"
                                        Value="Center" />
                            </Style>
                        </ResourceDictionary>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Full Name"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="Phone" />
                    <TextBlock Grid.Column="2"
                               Text="Email"
                          />
                    <TextBlock Grid.Column="3"
                               Text="Gender"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="4"
                               Text="Stage"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="5"
                               Text="Group"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="6"
                               Text="Code"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="7"
                               Text="Actions" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="40"
                          Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding fullName}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Phone}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Email}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Gender}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding Stage}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="5"
                                   Text="{Binding Group}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="6"
                                   Text="{Binding Code}"
                                   HorizontalAlignment="Center" />
                        <Button Grid.Column="7"
                                Background="Transparent"
                                BorderBrush="Transparent">
                            <SymbolIcon Symbol="More" />
                            <Button.Flyout>
                                <Flyout Placement="Left">
                                    <StackPanel Spacing="10">
                                        <Button Tag="{Binding id}"
                                                x:Name="UpdateStudent"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Click="UpdateStudent_Click"
                                                HorizontalContentAlignment="Left"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <SymbolIcon Symbol="Edit" />
                                                <TextBlock Text="Edit" />
                                            </StackPanel>
                                        </Button>
                                        <Button Tag="{Binding id}"
                                                x:Name="DeleteStudent"
                                                Click="DeleteStudent_Click"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <SymbolIcon Symbol="Delete" />
                                                <TextBlock Text="Delete" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
