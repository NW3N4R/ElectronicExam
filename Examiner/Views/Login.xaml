<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Examiner.Views.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Examiner.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Background="{ThemeResource LayerOnMicaBaseAltFillColorDefault}"
          CornerRadius="10"
          MinWidth="810"
          MinHeight="420">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*"
                              MinWidth="330" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Spacing="10"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Padding="20,10,20,10">
            <TextBlock Text="Welcome"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="Please Write Your Login Details"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource BodyStrongTextBlockStyle}" />

            <TextBox Header="Student's Phone Number"
                     PlaceholderText="phone number"
                     x:Name="StudentPhone"
                     Text="07701234560"
                     HorizontalAlignment="Stretch" />

            <TextBox Header="Student's private Code"
              PlaceholderText="your 10 char code"
              x:Name="StudentCode"
              Text="8B89E756"
              HorizontalAlignment="Stretch" />
            <Button Background="{StaticResource SystemAccentColor}"
                    Content="Submit"
                    x:Name="SubmitBttn"
                    Click="SubmitBttn_Click"
                    HorizontalAlignment="Stretch" />
        </StackPanel>
        <StackPanel  Grid.Column="1"
                     Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                     VerticalAlignment="Stretch"
                     x:Name="DetailsStack"
                     Visibility="Collapsed">
            <StackPanel Padding="10"
                        Spacing="20"
                        HorizontalAlignment="Left"
                        Margin="30,30,0,0">
                <StackPanel>
                    <TextBlock Text="Student Full Name"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding fullName}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Phone No"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{Binding Phone}"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="30">
                    <StackPanel>
                        <TextBlock Text="Stage"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Text="{Binding Stage}"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Group"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Text="{Binding Group}"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <ComboBox Header="Select An Exam"
                      x:Name="ExamSelector"
                      SelectedIndex="0"
                      Margin="30,30,30,0"
                      SelectedValuePath="id"
                      DisplayMemberPath="Title"
                      HorizontalAlignment="Stretch"
                      MinWidth="320"
                      SelectionChanged="ExamSelector_SelectionChanged"/>
            <Button x:Name="LoginBttn"
                    Click="LoginBttn_Click"
                    Margin="30,20,30,0"
                    Content="Get Start"
                    HorizontalAlignment="Right"
                    MinWidth="120"
                    Background="{StaticResource SystemAccentColor}" />
        </StackPanel>
    </Grid>
</Page>
